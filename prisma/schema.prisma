generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("collaborator") // admin | collaborator
  position  String?
  createdAt DateTime @default(now())

  assignedTasks      Task[]                @relation("AssignedTasks")
  createdTasks       Task[]                @relation("CreatedTasks")
  statusChanges      StatusHistory[]
  incidents          Incident[]
  permissions        UserPermission[]
  dailyTasks         DailyTask[]           @relation("DailyTaskAssignee")
  createdDailyTasks  DailyTask[]           @relation("DailyTaskCreator")
  goals              Goal[]                @relation("GoalAssignee")
  createdGoals       Goal[]                @relation("GoalCreator")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  priority    String    @default("medium") // low | medium | high | urgent
  status      String    @default("pending") // pending | in_progress | completed
  isRework    Boolean   @default(false)
  reworkCount Int       @default(0) // increments each time task is marked as rework
  onTime      Boolean?  // calculated on completion
  approved    Boolean   @default(false) // creator confirmed the completed task is correct
  approvedAt  DateTime?
  discordMessageId String? // Discord message posted on completion, edited when approved
  attachmentUrl   String? // file attached to the task, stored in Vercel Blob
  attachmentName  String?

  dueDate     DateTime
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  assigneeId String
  assignee   User   @relation("AssignedTasks", fields: [assigneeId], references: [id])
  creatorId  String
  creator    User   @relation("CreatedTasks", fields: [creatorId], references: [id])

  originalTaskId String?
  originalTask   Task?   @relation("ReworkOf", fields: [originalTaskId], references: [id])
  reworkTasks    Task[]  @relation("ReworkOf")

  statusHistory StatusHistory[]
}

model StatusHistory {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fromStatus String?
  toStatus   String
  changedById String
  changedBy  User     @relation(fields: [changedById], references: [id])
  changedAt  DateTime @default(now())
  note       String?
}

model Incident {
  id           String   @id @default(cuid())
  title        String
  description  String?
  category     String   // ops_down | service_failure | revenue_loss
  severity     String   // low | medium | high | critical
  occurredAt   DateTime
  createdAt    DateTime @default(now())
  reportedById String
  reportedBy   User     @relation(fields: [reportedById], references: [id])
  relatedUserId String?
}

// Recurring daily task template
model DailyTask {
  id          String   @id @default(cuid())
  title       String
  description String?
  priority    String   @default("medium")
  assigneeId  String
  assignee    User     @relation("DailyTaskAssignee", fields: [assigneeId], references: [id])
  creatorId   String
  creator     User     @relation("DailyTaskCreator", fields: [creatorId], references: [id])
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  completions DailyTaskCompletion[]
}

// Tracks whether a daily task was completed on a specific calendar day
model DailyTaskCompletion {
  id          String    @id @default(cuid())
  dailyTaskId String
  dailyTask   DailyTask @relation(fields: [dailyTaskId], references: [id], onDelete: Cascade)
  date        String    // "YYYY-MM-DD"
  completedAt DateTime  @default(now())
  userId      String

  @@unique([dailyTaskId, date])
}

// A goal assigned to a person (e.g. monthly targets), tracked until marked done
model Goal {
  id          String    @id @default(cuid())
  title       String
  description String?
  assigneeId  String
  assignee    User      @relation("GoalAssignee", fields: [assigneeId], references: [id])
  creatorId   String
  creator     User      @relation("GoalCreator", fields: [creatorId], references: [id])
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
}

// Granular per-user permissions
// action: create_task | move_in_progress | move_completed | mark_rework | create_incident | manage_permissions
model UserPermission {
  id      String  @id @default(cuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  action  String
  granted Boolean @default(true)

  @@unique([userId, action])
}
